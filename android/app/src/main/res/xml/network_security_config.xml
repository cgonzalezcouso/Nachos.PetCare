<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!--
        Política de seguridad de red para NachosPetCare.
        - cleartextTrafficPermitted="false": solo HTTPS, sin HTTP en claro.
        - Solo se confía en certificados del sistema (sin certificados de usuario).
    -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>

